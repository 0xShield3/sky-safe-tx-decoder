{
  "name": "sky-safe-tx-decoder",
  "version": "0.1.0",
  "private": true,
  "description": "TypeScript-based Safe multisig transaction hash calculator and decoder with custom protocol support",
  "keywords": [
    "safe",
    "gnosis-safe",
    "multisig",
    "eip-712",
    "transaction-hash"
  ],
  "author": "Security Alliance",
  "license": "AGPL-3.0-only",
  "repository": {
    "type": "git",
    "url": "https://github.com/0xShield3/sky-safe-tx-decoder"
  },
  "engines": {
    "node": ">=18.0.0",
    "pnpm": ">=10.0.0"
  },
  "packageManager": "pnpm@10.34.1",
  "scripts": {
    "build": "pnpm -r build",
    "test": "pnpm -r test",
    "lint": "pnpm -r lint",
    "format": "prettier --write \"**/*.{ts,tsx,json,md}\"",
    "clean": "pnpm -r clean && rm -rf node_modules",
    "dev:cli": "pnpm --filter @shield3/sky-safe-cli dev"
  },
  "devDependencies": {
    "@types/node": "20.19.41",
    "prettier": "3.8.3",
    "typescript": "5.9.3",
    "vitest": "2.1.9"
  },
  "pnpm": {
    "overrides": {
      "esbuild@<0.25.0": ">=0.25.0"
    }
  }
}
