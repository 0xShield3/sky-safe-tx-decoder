# Refuse to execute pre/post-install scripts from any package, including
# transitive dependencies. With ~400 transitive deps, any of them could ship
# a malicious lifecycle script that runs on `pnpm install` before our code
# ever executes. Build scripts for known packages can still be approved
# explicitly via `pnpm approve-builds`.
ignore-scripts=true

# Refuse to install any package version published in the last 7 days. Most
# malicious-package incidents are detected and yanked within hours; a 7-day
# soak window catches the common attack window without slowing routine work
# meaningfully. Bump up if a specific incident response calls for it.
# Requires pnpm >= 10.
minimum-release-age=10080
